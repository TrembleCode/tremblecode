# TrembleCode v2 — server settings (prefix TC_, read from server/.env or env)
# All optional; defaults shown.

# TC_DATABASE_URL=sqlite+aiosqlite:///./tremblecode.db
# TC_REDIS_URL=redis://localhost:6379/0
# TC_PORT=8400
# TC_PROJECTS_DIR=~/tremblecode-projects
# TC_AGENT_HOME=~/.tremblecode/agent-home
# TC_SANDBOX_IMAGE=tremblecode-sandbox:base
# TC_PORT_BLOCK_START=34000
# TC_INTERNAL_SECRET=change-me            # shared with sandboxes
# TC_FERNET_KEY=                          # auto-generated if empty
# TC_ACK_TIMEOUT_SECONDS=900
# TC_CORS_ORIGINS=["http://localhost:3000"]

# web/ reads:
# NEXT_PUBLIC_API_URL=http://localhost:8400
