{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tremblecode-hook session-start --agent {{ agent_name }}",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tremblecode-hook busy --agent {{ agent_name }} || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "tremblecode-hook heartbeat --agent {{ agent_name }} || true",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tremblecode-hook stop --agent {{ agent_name }} || true",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tremblecode-hook subagent-stop --agent {{ agent_name }} || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tremblecode-hook pre-compact --agent {{ agent_name }} || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tremblecode-hook notification --agent {{ agent_name }} || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
